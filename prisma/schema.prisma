generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model content {
  id        String   @id @default(cuid())
  data      String   @db.LongText
  updatedAt DateTime
}

model photo {
  id           String   @id @default(cuid())
  url          String   @db.Text
  originalName String
  uploaderName String
  approved     Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model rsvp {
  id        String   @id @default(cuid())
  name      String
  email     String
  attending Boolean
  guests    Int      @default(1)
  dietary   String?
  message   String?  @db.Text
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
}
